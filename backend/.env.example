# Ollama connection (defaults to Ollama Cloud)
# Host is a bare origin, no /v1 suffix (native API). For a local instance use http://127.0.0.1:11434
OLLAMA_HOST=https://ollama.com
# Create a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# Default model used when a request doesn't specify one
DEFAULT_MODEL=kimi-k2.5:cloud

# Server configuration
PORT=3000

# Database path (optional)
# DB_PATH=/path/to/chat.db
